---
// The single deep teal section — the only major color break on the page.
// The emotional peak. Everything has been building to this.
---

<section
  class="covenant-cta relative overflow-hidden"
  aria-label="Begin your sponsorship"
  style="background-color: var(--color-teal);"
>
  <!-- SVG grain texture — tactile depth on the teal surface -->
  <svg
    class="absolute inset-0 w-full h-full pointer-events-none"
    style="opacity: 0.045;"
    aria-hidden="true"
    xmlns="http://www.w3.org/2000/svg"
  >
    <filter id="cta-grain">
      <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/>
      <feColorMatrix type="saturate" values="0"/>
    </filter>
    <rect width="100%" height="100%" filter="url(#cta-grain)"/>
  </svg>

  <!-- Floating geometric particles — gold, CSS animated -->
  <div class="cta-particles absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <!-- Diamond, top-left -->
    <svg class="particle particle-1" width="10" height="10" viewBox="0 0 10 10" fill="none"
      style="position:absolute; top:15%; left:8%;">
      <path d="M5 0L10 5L5 10L0 5Z" stroke="#C4952A" stroke-width="0.8" fill="none"/>
    </svg>
    <!-- Circle, top-right -->
    <svg class="particle particle-2" width="7" height="7" viewBox="0 0 7 7"
      style="position:absolute; top:22%; right:11%;">
      <circle cx="3.5" cy="3.5" r="3" stroke="#C4952A" stroke-width="0.8" fill="none"/>
    </svg>
    <!-- Large diamond, mid-left -->
    <svg class="particle particle-3" width="14" height="14" viewBox="0 0 14 14" fill="none"
      style="position:absolute; top:45%; left:5%;">
      <path d="M7 0L14 7L7 14L0 7Z" stroke="#C4952A" stroke-width="0.8" fill="none"/>
    </svg>
    <!-- Circle, mid-right -->
    <svg class="particle particle-4" width="8" height="8" viewBox="0 0 8 8"
      style="position:absolute; top:52%; right:7%;">
      <circle cx="4" cy="4" r="3.5" stroke="#C4952A" stroke-width="0.8" fill="none"/>
    </svg>
    <!-- Small diamond, lower-left -->
    <svg class="particle particle-5" width="8" height="8" viewBox="0 0 8 8" fill="none"
      style="position:absolute; bottom:28%; left:14%;">
      <path d="M4 0L8 4L4 8L0 4Z" stroke="#C4952A" stroke-width="0.8" fill="none"/>
    </svg>
    <!-- 8-point star, lower-right -->
    <svg class="particle particle-6" width="16" height="16" viewBox="0 0 28 28" fill="none"
      style="position:absolute; bottom:22%; right:16%;">
      <path d="M14 2L16.1 9.9L22.6 5.4L18.1 11.9L26 14L18.1 16.1L22.6 22.6L16.1 18.1L14 26L11.9 18.1L5.4 22.6L9.9 16.1L2 14L9.9 11.9L5.4 5.4L11.9 9.9Z" stroke="#C4952A" stroke-width="1" fill="none"/>
    </svg>
    <!-- Tiny circle, upper-center-right -->
    <svg class="particle particle-7" width="5" height="5" viewBox="0 0 5 5"
      style="position:absolute; top:32%; right:27%;">
      <circle cx="2.5" cy="2.5" r="2" stroke="#C4952A" stroke-width="0.8" fill="none"/>
    </svg>
  </div>

  <div class="container relative z-10 py-32 lg:py-40 text-center">

    <div class="aos max-w-2xl mx-auto" data-reveal="wipe">
      <!-- Gold divider above -->
      <div class="flex justify-center mb-12" aria-hidden="true">
        <svg width="80" height="2" viewBox="0 0 80 2">
          <line x1="0" y1="1" x2="80" y2="1"
            stroke="#C4952A" stroke-width="1"
            class="geo-line-path"
          />
        </svg>
      </div>

      <h2
        class="font-heading mb-8"
        style="color: var(--color-teal-text); font-size: clamp(2rem, 5vw, 3.5rem); letter-spacing: -0.02em; line-height: 1.1;"
      >
        Begin your covenant today.
      </h2>

      <p
        class="font-body mb-12 mx-auto"
        style="color: rgba(253,250,245,0.8); font-size: 1.125rem; line-height: 1.65; max-width: 38rem;"
      >
        A monthly sponsorship is more than a donation.
        It's a promise that continues to give — to a child who needs you,
        and a sadaqah jariyah that returns to you.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/sponsor"
          class="cta-btn-light"
          aria-label="Sponsor an Orphan — Begin your monthly commitment"
        >
          Sponsor an Orphan
        </a>
        <a
          href="/donate"
          class="cta-btn-outline"
          aria-label="Make a one-time donation"
        >
          One-time Donation
        </a>
      </div>

      <!-- Tax deductible note -->
      <p class="mt-8 font-body text-xs" style="color: rgba(253,250,245,0.5); letter-spacing: 0.04em; text-transform: uppercase;">
        Tax deductible in Canada &nbsp;·&nbsp; Registered Charity #891782436 RR 0001
      </p>
    </div>

  </div>
</section>

<style>
  .cta-btn-light {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2rem;
    background-color: #C4952A;
    color: #1C1208;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    min-width: 200px;
    transition: background-color var(--duration-fast) var(--ease-out-quart);
  }

  .cta-btn-light:hover {
    background-color: #D4A84B;
  }

  .cta-btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: calc(1rem - 1px) calc(2rem - 1px);
    background-color: transparent;
    color: var(--color-teal-text);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    border: 1px solid rgba(253,250,245,0.3);
    min-width: 200px;
    transition: border-color var(--duration-fast) var(--ease-out-quart);
  }

  .cta-btn-outline:hover {
    border-color: rgba(253,250,245,0.7);
  }

  /* Floating particle animations */
  .particle {
    opacity: 0.14;
    will-change: transform;
  }

  @keyframes float-up {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-6px); }
  }

  @keyframes float-down {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(6px); }
  }

  .particle-1 { animation: float-up   3.8s ease-in-out infinite; animation-delay:  0s; }
  .particle-2 { animation: float-down 4.2s ease-in-out infinite; animation-delay: -1.1s; }
  .particle-3 { animation: float-up   5.0s ease-in-out infinite; animation-delay: -2.3s; }
  .particle-4 { animation: float-down 3.5s ease-in-out infinite; animation-delay: -0.7s; }
  .particle-5 { animation: float-up   4.8s ease-in-out infinite; animation-delay: -1.8s; }
  .particle-6 { animation: float-down 4.0s ease-in-out infinite; animation-delay: -3.1s; }
  .particle-7 { animation: float-up   3.2s ease-in-out infinite; animation-delay: -0.4s; }
</style>
