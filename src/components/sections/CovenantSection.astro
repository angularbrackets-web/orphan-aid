---
const pillars = [
  {
    icon: 'education',
    title: 'Education',
    body: 'Every sponsored child receives access to quality schooling, learning materials, and ongoing academic support — building the foundation for a self-sufficient future.',
    image: {
      src: 'https://images.unsplash.com/photo-1503454537195-1dcabb73ffb9?w=600&q=85&auto=format&fit=crop',
      alt: 'A child engaged in reading and learning.',
    },
  },
  {
    icon: 'health',
    title: 'Healthcare',
    body: 'Regular medical check-ups, vaccinations, and emergency care are covered. No child under our care faces illness without support.',
    image: {
      src: 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=600&q=85&auto=format&fit=crop',
      alt: 'A child receiving attentive care and support.',
    },
  },
  {
    icon: 'care',
    title: 'Daily Care',
    body: 'Nutritious food, clothing, and a safe environment are the basics every child deserves. Your sponsorship ensures these are never in question.',
    image: {
      src: 'https://images.unsplash.com/photo-1529390079861-591de354faf5?w=600&q=85&auto=format&fit=crop',
      alt: 'Children together in a safe and nurturing environment.',
    },
  },
]

const icons: Record<string, string> = {
  education: 'M14 2L17.5 10.5L26 14L17.5 17.5L14 26L10.5 17.5L2 14L10.5 10.5Z',
  health:    'M10 2L18 2L26 10L26 18L18 26L10 26L2 18L2 10Z',
  care:      'M14 1L16.9 7.6L24 4.6L21 11.7L28 14L21 16.3L24 23.4L16.9 20.4L14 27L11.1 20.4L4 23.4L7 16.3L0 14L7 11.7L4 4.6L11.1 7.6Z',
}
---

<!-- ============================================================
  PROPHETIC QUOTE — visually distinct dark band
  ============================================================ -->
<section class="quote-band" aria-label="Prophetic guidance">
  <!-- Decorative geo line top -->
  <div class="container" aria-hidden="true">
    <svg class="geo-line-svg" viewBox="0 0 1200 2" height="2" preserveAspectRatio="none">
      <line x1="0" y1="1" x2="1200" y2="1" stroke="rgba(196,149,42,0.3)" stroke-width="1" class="geo-line-path"/>
    </svg>
  </div>

  <div class="container quote-band-inner">
    <div class="aos max-w-3xl mx-auto text-center">
      <!-- Large decorative opening mark -->
      <div class="quote-mark-wrap" aria-hidden="true">
        <span class="quote-mark">&ldquo;</span>
      </div>

      <blockquote>
        <p
          class="font-heading italic quote-text"
          lang="en"
        >
          The one who cares for an orphan and I will be in Paradise like these two.
        </p>
        <footer class="mt-8">
          <div class="flex items-center justify-center gap-4 mb-3" aria-hidden="true">
            <span class="quote-line"></span>
            <svg width="14" height="14" viewBox="0 0 28 28" fill="none">
              <path d="M14 2L16.1 9.9L22.6 5.4L18.1 11.9L26 14L18.1 16.1L22.6 22.6L16.1 18.1L14 26L11.9 18.1L5.4 22.6L9.9 16.1L2 14L9.9 11.9L5.4 5.4L11.9 9.9Z" stroke="#C4952A" stroke-width="1" fill="none"/>
            </svg>
            <span class="quote-line"></span>
          </div>
          <cite class="quote-attribution not-italic">
            Prophet Muhammad ﷺ &mdash; Sahih al-Bukhari
          </cite>
        </footer>
      </blockquote>
    </div>
  </div>

  <!-- Decorative geo line bottom -->
  <div class="container" aria-hidden="true">
    <svg class="geo-line-svg" viewBox="0 0 1200 2" height="2" preserveAspectRatio="none">
      <line x1="0" y1="1" x2="1200" y2="1" stroke="rgba(196,149,42,0.3)" stroke-width="1" class="geo-line-path"/>
    </svg>
  </div>
</section>

<!-- ============================================================
  THREE PILLARS — parchment, with editorial portrait images
  ============================================================ -->
<section class="section" aria-label="What your sponsorship covers">
  <div class="container">

    <!-- Section heading -->
    <div class="aos mb-16 max-w-xl" data-reveal="wipe">
      <p class="label mb-4">Your sponsorship covers</p>
      <h2 class="h2 text-ink">
        Three pillars that<br />change a child's life.
      </h2>
    </div>

    <!-- Pillars — editorial column layout, asymmetric -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">

      <!-- Pillar 1 — wide left -->
      <div class="lg:col-span-5 aos" data-delay="0">
        <div class="pillar-image-inner mb-8">
          <img
            src={pillars[0].image.src}
            alt={pillars[0].image.alt}
            class="pillar-img"
            loading="lazy"
            decoding="async"
          />
          <div class="pillar-img-overlay" aria-hidden="true"></div>
          <div class="pillar-img-hover-overlay" aria-hidden="true"></div>
        </div>
        <div class="mb-5" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <path d={icons.education} stroke="#C4952A" stroke-width="1" fill="none"/>
          </svg>
        </div>
        <h3 class="h3 text-ink mb-4">{pillars[0].title}</h3>
        <p class="font-body text-base text-ink-secondary leading-relaxed prose-width">{pillars[0].body}</p>
      </div>

      <!-- Pillar 2 — offset right -->
      <div class="lg:col-span-4 lg:col-start-7 lg:mt-24 aos" data-delay="0.1">
        <div class="pillar-image-inner mb-8">
          <img
            src={pillars[1].image.src}
            alt={pillars[1].image.alt}
            class="pillar-img"
            loading="lazy"
            decoding="async"
          />
          <div class="pillar-img-overlay" aria-hidden="true"></div>
          <div class="pillar-img-hover-overlay" aria-hidden="true"></div>
        </div>
        <div class="mb-5" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <path d={icons.health} stroke="#C4952A" stroke-width="1" fill="none"/>
          </svg>
        </div>
        <h3 class="h3 text-ink mb-4">{pillars[1].title}</h3>
        <p class="font-body text-base text-ink-secondary leading-relaxed">{pillars[1].body}</p>
      </div>

      <!-- Pillar 3 — back left -->
      <div class="lg:col-span-5 lg:mt-4 aos" data-delay="0.2">
        <div class="pillar-image-inner mb-8">
          <img
            src={pillars[2].image.src}
            alt={pillars[2].image.alt}
            class="pillar-img"
            loading="lazy"
            decoding="async"
          />
          <div class="pillar-img-overlay" aria-hidden="true"></div>
          <div class="pillar-img-hover-overlay" aria-hidden="true"></div>
        </div>
        <div class="mb-5" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <path d={icons.care} stroke="#C4952A" stroke-width="1" fill="none"/>
          </svg>
        </div>
        <h3 class="h3 text-ink mb-4">{pillars[2].title}</h3>
        <p class="font-body text-base text-ink-secondary leading-relaxed prose-width">{pillars[2].body}</p>
      </div>

    </div>

  </div>
</section>

<style>
  /* ============ QUOTE BAND ============ */
  .quote-band {
    background-color: #1C1208;
    position: relative;
  }

  .quote-band-inner {
    padding-top: 6rem;
    padding-bottom: 6rem;
  }

  @media (min-width: 1024px) {
    .quote-band-inner {
      padding-top: 8rem;
      padding-bottom: 8rem;
    }
  }

  .quote-mark-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .quote-mark {
    font-family: var(--font-heading);
    font-size: clamp(5rem, 12vw, 9rem);
    line-height: 0.6;
    color: #C4952A;
    opacity: 0.35;
    display: block;
    font-style: italic;
  }

  .quote-text {
    font-size: clamp(1.6rem, 4vw, 2.8rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: rgba(253, 250, 245, 0.92);
  }

  .quote-line {
    display: inline-block;
    width: 40px;
    height: 1px;
    background-color: rgba(196, 149, 42, 0.4);
  }

  .quote-attribution {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: rgba(253, 250, 245, 0.45);
    display: block;
  }

  /* ============ PILLAR IMAGES ============ */
  .pillar-image-inner {
    position: relative;
    overflow: hidden;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 2px;
  }

  .pillar-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transform-origin: center center;
    transition: transform 0.85s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Permanent bottom-to-top gradient overlay */
  .pillar-img-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(to top, rgba(28,18,8,0.35) 0%, transparent 50%);
  }

  /* Hover gold tint — fades in on hover */
  .pillar-img-hover-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: rgba(196, 149, 42, 0.0);
    transition: background 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .pillar-image-inner:hover .pillar-img {
    transform: scale(1.05);
  }

  .pillar-image-inner:hover .pillar-img-hover-overlay {
    background: rgba(196, 149, 42, 0.12);
  }

  @media (prefers-reduced-motion: reduce) {
    .pillar-img,
    .pillar-img-hover-overlay {
      transition: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

  if (!prefersReducedMotion) {
    // Subtle parallax on pillar images — inner image moves, wrapper clips
    document.querySelectorAll('.pillar-img').forEach((img) => {
      gsap.to(img, {
        yPercent: -8,
        ease: 'none',
        scrollTrigger: {
          trigger: img,
          start: 'top bottom',
          end: 'bottom top',
          scrub: true,
        },
      })
    })
  }
</script>
