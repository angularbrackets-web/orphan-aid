---
// Compare page — Option B: Dark Olive #2A3318
// Visit /compare to see Option B alongside Option A at /
import Layout from '@/layouts/Layout.astro'
import HeroV2 from '@/components/sections/HeroV2.astro'
import QuoteBar from '@/components/sections/QuoteBar.astro'
import ImpactStats from '@/components/sections/ImpactStats.astro'
import StoryRows from '@/components/sections/StoryRows.astro'
import DisplayMoment from '@/components/sections/DisplayMoment.astro'
import ChildProfiles from '@/components/sections/ChildProfiles.astro'
import AmountPickerSection from '@/components/sections/AmountPickerSection.astro'
import DonorTestimonials from '@/components/sections/DonorTestimonials.astro'
import CovenantCTAV2 from '@/components/sections/CovenantCTAV2.astro'
---

<Layout
  title="Compare — Option B"
  description="Color comparison — Option B Dark Olive"
  canonical="/compare"
>
  <!-- Option B overrides: Dark Olive #2A3318 -->
  <!-- RGB: 42, 51, 24 -->
  <div style="--color-teal: #2A3318; --color-teal-hover: #1E280F; --color-teal-rgb: 42, 51, 24;">
    <HeroV2 />
    <QuoteBar />
    <ImpactStats variant="teal-band" />
    <StoryRows />
    <DisplayMoment />
    <ChildProfiles />
    <AmountPickerSection />
    <DonorTestimonials />
    <CovenantCTAV2 />
  </div>
</Layout>
