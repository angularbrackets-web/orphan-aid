---
import Layout from '@/layouts/Layout.astro'
---

<Layout
  title="Privacy Policy"
  description="Read the privacy policy for Orphan Aid, a registered Canadian charity. Learn how we collect, use, and protect your personal information."
  canonical="/privacy"
>
  <section class="page-hero" aria-label="Privacy Policy">
    <div class="container py-48 lg:py-56">
      <div class="max-w-2xl">
        <p class="label mb-6">Legal</p>
        <h1 class="h1 text-ink mb-8">Privacy Policy</h1>
        <p class="font-body text-lg text-ink-secondary leading-relaxed mb-6">
          Our Privacy Policy is currently being prepared. It will be published here shortly.
        </p>
        <p class="font-body text-base text-ink-secondary leading-relaxed">
          For any questions regarding how we collect, use, or protect your personal information,
          please contact us at <a href="mailto:info@orphanaid.com" class="text-ink underline underline-offset-2">info@orphanaid.com</a>.
        </p>
      </div>
    </div>
  </section>
</Layout>
