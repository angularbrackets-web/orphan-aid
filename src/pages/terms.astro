---
import Layout from '@/layouts/Layout.astro'
---

<Layout
  title="Terms of Use"
  description="Read the terms of use for Orphan Aid, a registered Canadian charity. Governing the use of our website and online services."
  canonical="/terms"
>
  <section class="page-hero" aria-label="Terms of Use">
    <div class="container py-48 lg:py-56">
      <div class="max-w-2xl">
        <p class="label mb-6">Legal</p>
        <h1 class="h1 text-ink mb-8">Terms of Use</h1>
        <p class="font-body text-lg text-ink-secondary leading-relaxed mb-6">
          Our Terms of Use are currently being prepared. They will be published here shortly.
        </p>
        <p class="font-body text-base text-ink-secondary leading-relaxed">
          For any questions regarding use of this website or our services,
          please contact us at <a href="mailto:info@orphanaid.com" class="text-ink underline underline-offset-2">info@orphanaid.com</a>.
        </p>
      </div>
    </div>
  </section>
</Layout>
