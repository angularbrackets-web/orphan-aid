---
import Layout from '@/layouts/Layout.astro'
import CovenantCTA from '@/components/sections/CovenantCTA.astro'
---

<Layout
  title="Donate"
  description="Support Orphan Aid with a one-time or recurring donation. Every contribution provides care, education, and support for orphaned children worldwide."
  canonical="/donate"
  keywords={['donate to orphan charity Canada', 'Islamic charity donation', 'tax deductible charity Canada', 'donate orphan aid', 'sadaqah Canada']}
>
  <section class="page-hero" aria-label="Donate to Orphan Aid">
    <div class="container py-48 lg:py-56">
      <div class="max-w-3xl">
        <p class="label mb-6">Support Our Mission</p>
        <h1 class="h1 text-ink mb-6">
          Every contribution<br />
          <em style="font-style: italic;">keeps a promise.</em>
        </h1>
        <div class="w-16 my-8" aria-hidden="true">
          <svg width="64" height="2" viewBox="0 0 64 2">
            <line x1="0" y1="1" x2="64" y2="1" stroke="#C4952A" stroke-width="1.5" class="geo-line-path"/>
          </svg>
        </div>
        <p class="font-body text-lg text-ink-secondary leading-relaxed" style="max-width: 32rem;">
          Whether a one-time sadaqah or a recurring gift,
          your generosity directly funds the care of orphaned children worldwide.
          All donations are tax-deductible in Canada.
        </p>
      </div>
    </div>
  </section>

  <div class="container" aria-hidden="true">
    <svg class="geo-line-svg" viewBox="0 0 1200 2" height="2" preserveAspectRatio="none">
      <line x1="0" y1="1" x2="1200" y2="1" stroke="#D4A84B" stroke-width="1" class="geo-line-path"/>
    </svg>
  </div>

  <!-- Donation options -->
  <section class="section" aria-label="Donation options">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Monthly -->
        <div class="aos">
          <div class="mb-6" aria-hidden="true">
            <div class="w-8 h-px bg-gold"></div>
          </div>
          <h2 class="h2 text-ink mb-4">Monthly Giving</h2>
          <p class="font-body text-base text-ink-secondary leading-relaxed mb-8">
            A recurring monthly donation is the most impactful way to support our work.
            It allows us to plan long-term programmes, maintain staffing, and ensure
            no child's care is interrupted. Your sadaqah jariyah continues every month,
            without you having to do anything.
          </p>
          <a href="/sponsor" class="btn-teal">Sponsor an Orphan Monthly</a>
        </div>

        <!-- One-time -->
        <div class="aos" data-delay="0.1">
          <div class="mb-6" aria-hidden="true">
            <div class="w-8 h-px bg-gold"></div>
          </div>
          <h2 class="h2 text-ink mb-4">One-Time Donation</h2>
          <p class="font-body text-base text-ink-secondary leading-relaxed mb-8">
            A single gift — whether $20 or $2,000 — is received with deep gratitude
            and directed entirely to child care programmes. No amount is too small.
            Every contribution adds to the covenant we keep with children worldwide.
          </p>
          <!-- Placeholder CTA — no payment gateway in v1 -->
          <a href="/contact" class="btn-ghost-ink">
            Contact Us to Donate
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- Where your money goes -->
  <section class="section bg-bg-subtle" aria-label="Where donations go">
    <div class="container">
      <div class="aos mb-16">
        <p class="label mb-4">Transparency</p>
        <h2 class="h2 text-ink">Where your money goes.</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        {[
          { pct: '85%', label: 'Direct child care', detail: 'Education, healthcare, meals, shelter' },
          { pct: '10%', label: 'Programme support', detail: 'Field staff, local partnerships' },
          { pct: '5%',  label: 'Administration',   detail: 'Compliance, reporting, operations' },
        ].map((item, i) => (
          <div class="aos" data-delay={String(i * 0.1)}>
            <p
              class="font-heading text-ink mb-2"
              style="font-size: clamp(2.5rem, 5vw, 3.5rem); letter-spacing: -0.03em; line-height: 1;"
            >
              {item.pct}
            </p>
            <p class="label mb-1">{item.label}</p>
            <p class="font-body text-sm text-ink-muted">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CovenantCTA />
</Layout>

<style>
  .page-hero { background-color: var(--color-bg); padding-top: 5rem; }
  .btn-teal {
    display: inline-flex; align-items: center; padding: 1rem 2rem;
    background-color: var(--color-teal); color: var(--color-teal-text);
    font-family: var(--font-body); font-size: var(--text-xs); font-weight: 600;
    letter-spacing: var(--tracking-widest); text-transform: uppercase;
    text-decoration: none; border-radius: 2px;
    transition: background-color var(--duration-fast) var(--ease-out-quart);
  }
  .btn-teal:hover { background-color: var(--color-teal-hover); }
  .btn-ghost-ink {
    display: inline-flex; align-items: center; padding: calc(1rem - 1px) calc(2rem - 1px);
    background-color: transparent; color: var(--color-text);
    font-family: var(--font-body); font-size: var(--text-xs); font-weight: 600;
    letter-spacing: var(--tracking-widest); text-transform: uppercase;
    text-decoration: none; border-radius: 2px; border: 1px solid var(--color-border);
    transition: border-color var(--duration-fast) var(--ease-out-quart);
  }
  .btn-ghost-ink:hover { border-color: var(--color-text); }
</style>
